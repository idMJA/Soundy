{
  "name": "soundy",
  "version": "3.6.0",
  "description": "A powerful music bot built with Seyfert and lavalink-client to play high quality music in your Discord server for free.",
  "author": {
    "name": "Kiyomi Fujiwara",
    "email": "kiyomi@mja.moe",
    "url": "https://github.com/idMJA"
  },
  "license": "AGPL-3.0",
  "homepage": "https://github.com/idMJA/Soundy",
  "repository": {
    "type": "git",
    "url": "https://github.com/idMJA/Soundy"
  },
  "bugs": {
    "url": "https://github.com/idMJA/Soundy/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "encrypt": "dotenvx encrypt",
    "build": "tsup",
    "format": "biome check --write ./src",
    "lint": "tsc --noEmit && biome check --write ./src",
    "db:generate": "dotenvx run -- drizzle-kit generate",
    "db:migrate": "dotenvx run -- drizzle-kit migrate",
    "db:studio": "dotenvx run -- drizzle-kit studio",
    "db:push": "dotenvx run -- drizzle-kit push"
  },
  "lint-staged": {
    "*.ts": [
      "bun format"
    ]
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@mjba/lyrics": "^1.2.1",
    "@top-gg/sdk": "^3.1.6",
    "@tursodatabase/database": "^0.6.1",
    "@tursodatabase/sync": "^0.6.1",
    "axios": "^1.18.1",
    "drizzle-orm": "^1.0.0-rc.4",
    "elysia": "^1.4.29",
    "genius-lyrics": "^4.4.7",
    "jsonwebtoken": "^9.0.3",
    "lavalink-client": "^2.10.3",
    "lowdb": "^7.0.1",
    "seyfert": "^4.4.0",
    "yunaforseyfert": "^1.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "drizzle-kit": "^1.0.0-rc.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild"
  ],
  "keywords": [
    "discord",
    "bot",
    "music",
    "lavalink",
    "seyfert",
    "typescript",
    "discord-bot",
    "music-bot"
  ]
}
